# ==============================================================================
# SNW CAD Onderlegger - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file to version control.
# ==============================================================================

# --- Authentication ---
APP_USERNAME=admin
APP_PASSWORD=admin

# --- Output / Cleanup ---
OUTPUT_DIR=output_onderlegger
CLEANUP_MAX_AGE_HOURS=24
CLEANUP_INTERVAL_MINUTES=30

# --- Logging ---
LOG_LEVEL=INFO

# --- API Keys (reserve for future use; PDOK is open data) ---
PDOK_API_KEY=
PEXELS_API_KEY=
